# Trading OS — credential template.
# Copy this file to ".env" at the repo root and fill in real values.
# The real .env is gitignored and must NEVER be committed.
# In production these are injected by the deployment environment / secrets
# manager instead of a file; the code reads them identically either way.

# St. Louis Fed FRED/ALFRED API key (free): https://fred.stlouisfed.org -> My Account -> API Keys
TRADING_OS_FRED_KEY=

# PostgreSQL connection (libpq conninfo). Default if unset: dbname=tradingos
# TRADING_OS_PG=dbname=tradingos

# Parquet lake root. Default if unset: lake
# TRADING_OS_LAKE=lake

# SEC EDGAR requires a descriptive User-Agent with real contact info.
# TRADING_OS_SEC_UA=Your Name your-email@example.com